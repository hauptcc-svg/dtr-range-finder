{
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://dtr-range-finder-production.up.railway.app/api/$1"
    },
    {
      "src": "/health",
      "dest": "https://dtr-range-finder-production.up.railway.app/health"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
